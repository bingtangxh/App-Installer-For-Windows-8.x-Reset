<Event>
<Name>È«¾Öº¯Êý</Name>
<Args/>
<Script>

function CompareVersion(verstrl, verstrr)
	return String.CompareFileVersions (verstrl, verstrr);
end

-- ============================================
-- º¯Êý£ºParseSetupArgs
-- ÃèÊö£º½âÎöÔöÇ¿µÄ°²×°³ÌÐòÃüÁîÐÐ²ÎÊý
-- ·µ»Ø£º
--   isAutoMode (boolean): ÊÇ·ñÎª×Ô¶¯/¾²Ä¬Ä£Ê½
--   customInstallPath (string or nil): ×Ô¶¨ÒåµÄ°²×°Â·¾¶£¨ÍêÕû»ò»ùÓÚ/to£©
--   showHelp (boolean): ÊÇ·ñÏÔÊ¾°ïÖúÐÅÏ¢
-- ============================================
function ParseSetupArgs()
    local args = _CommandLineArgs or {}
    local isAutoMode = false
    local customInstallPath = nil
    local showHelp = false
    local pathParamUsed = nil -- ¼ÇÂ¼Ê¹ÓÃµÄÊÇÄÄ¸öÂ·¾¶²ÎÊý£¬ÓÃÓÚ°ïÖúÐÅÏ¢

    -- Ö§³ÖµÄ×Ô¶¯Ä£Ê½²ÎÊýÁÐ±í£¨²»Çø·Ö´óÐ¡Ð´£©
    local autoModeFlags = {
        "/S", "/SILENT", "/PASSIVE", "/QUIET", "/AUTO",
        "-S", "-SILENT", "-PASSIVE", "-QUIET", "-AUTO",
        "S", "SILENT", "PASSIVE", "QUIET", "AUTO" -- ÎÞÇ°×º
    }
    
    -- Ö§³ÖµÄ°ïÖú²ÎÊýÁÐ±í
    local helpFlags = {
        "/?", "/HELP", "/H",
        "-?", "-HELP", "-H",
        "?", "HELP", "H"
    }

    local i = 1
    while i &lt;= #args do
        local arg = args[i]
        local argUpper = String.Upper(arg)
        local argFound = false

        -- 1. ¼ì²éÊÇ·ñÎª×Ô¶¯Ä£Ê½²ÎÊý
        for _, flag in ipairs(autoModeFlags) do
            if argUpper == String.Upper(flag) then
                isAutoMode = true
                argFound = true
                break
            end
        end
        
        -- 2. ¼ì²éÊÇ·ñÎª°ïÖú²ÎÊý
        if not argFound then
            for _, flag in ipairs(helpFlags) do
                if argUpper == String.Upper(flag) then
                    showHelp = true
                    argFound = true
                    break
                end
            end
        end
        
        -- 3. ¼ì²éÊÇ·ñÎªÂ·¾¶²ÎÊý (/to »ò /dir)
        -- ´¦ÀíÀàËÆ /to:"D:\" »ò /dir:"C:\NewPath" µÄ¸ñÊ½
        if not argFound then
            if String.Left(argUpper, 4) == "/TO:" or 
               String.Left(argUpper, 4) == "-TO:" or
               (String.Left(argUpper, 3) == "TO:" and #arg &gt; 3) then
               
                -- ÌáÈ¡Â·¾¶²¿·Ö£¨È¥µô²ÎÊýÇ°×º£©
                local prefixLen = arg:find(":", 1, true) or 3
                local rawPath = String.Mid(arg, prefixLen + 1)
                -- È¥µô¿ÉÄÜ°ü¹üµÄÒýºÅ
                rawPath = String.Trim(rawPath, "\"")
                rawPath = String.Trim(rawPath, "'")
                
                if rawPath ~= "" then
                    pathParamUsed = "/TO"
                    -- /TOÂß¼­£º½ö¸Ä±äÇý¶¯Æ÷»òÉÏ¼¶Ä¿Â¼£¬±£ÁôÄ¬ÈÏµÄÄ©Î²ÎÄ¼þ¼ÐÃû
                    local defaultPath = SessionVar.Expand("%ProgramFiles%") .. "\\MyApp"
                    local defaultFolderName = String.GetRightFrom(defaultPath, "\\")
                    if defaultFolderName then
                        -- È·±£Â·¾¶ÒÔ·´Ð±¸Ü½áÎ²£¬ÔÙÆ´½ÓÎÄ¼þ¼ÐÃû
                        if not String.Right(rawPath, 1) == "\\" then
                            rawPath = rawPath .. "\\"
                        end
                        customInstallPath = rawPath .. defaultFolderName
                    else
                        customInstallPath = rawPath -- »ØÍË·½°¸
                    end
                end
                argFound = true
                
            elseif String.Left(argUpper, 5) == "/DIR:" or 
                   String.Left(argUpper, 5) == "-DIR:" or
                   (String.Left(argUpper, 4) == "DIR:" and #arg &gt; 4) then
               
                local prefixLen = arg:find(":", 1, true) or 4
                local rawPath = String.Mid(arg, prefixLen + 1)
                rawPath = String.Trim(rawPath, "\"")
                rawPath = String.Trim(rawPath, "'")
                
                if rawPath ~= "" then
                    pathParamUsed = "/DIR"
                    -- /DIRÂß¼­£ºÖ±½ÓÊ¹ÓÃÓÃ»§Ìá¹©µÄÍêÕûÂ·¾¶
                    customInstallPath = rawPath
                end
                argFound = true
            end
        end
        
        -- 4. ´¦Àí¡°²ÎÊýÃû¡±ºÍ¡°¿Õ¸ñ·Ö¸ôµÄÖµ¡±µÄ¸ñÊ½£¨Èç /to "D:\"£©
        if not argFound then
            if argUpper == "/TO" or argUpper == "-TO" or argUpper == "TO" then
                pathParamUsed = "/TO"
                if i + 1 &lt;= #args then
                    local nextArg = args[i + 1]
                    if not String.Left(nextArg, 1) == "/" and not String.Left(nextArg, 1) == "-" then
                        local rawPath = nextArg
                        rawPath = String.Trim(rawPath, "\"")
                        rawPath = String.Trim(rawPath, "'")
                        -- Ó¦ÓÃÓëÉÏ·½ÏàÍ¬µÄ /TO Âß¼­¹¹½¨Â·¾¶
                        local defaultPath = SessionVar.Expand("%ProgramFiles%") .. "\\MyApp"
                        local defaultFolderName = String.GetRightFrom(defaultPath, "\\")
                        if defaultFolderName then
                            if not String.Right(rawPath, 1) == "\\" then
                                rawPath = rawPath .. "\\"
                            end
                            customInstallPath = rawPath .. defaultFolderName
                        end
                        i = i + 1 -- ¶îÍâÏûºÄÒ»¸ö²ÎÊý×÷ÎªÖµ
                    end
                end
                argFound = true
                
            elseif argUpper == "/DIR" or argUpper == "-DIR" or argUpper == "DIR" then
                pathParamUsed = "/DIR"
                if i + 1 &lt;= #args then
                    local nextArg = args[i + 1]
                    if not String.Left(nextArg, 1) == "/" and not String.Left(nextArg, 1) == "-" then
                        customInstallPath = String.Trim(nextArg, "\"")
                        customInstallPath = String.Trim(customInstallPath, "'")
                        i = i + 1
                    end
                end
                argFound = true
            end
        end
        
        i = i + 1
    end
    
    return isAutoMode, customInstallPath, showHelp, pathParamUsed
end

-- ============================================
-- º¯Êý£ºShowHelpAndExit
-- ÃèÊö£ºÏÔÊ¾²ÎÊý°ïÖúÐÅÏ¢²¢ÍË³ö°²×°³ÌÐò
-- ============================================
function ShowHelpAndExit()
    local helpText = [[
MyApp Installer - ÃüÁîÐÐ²ÎÊý°ïÖú

×Ô¶¯°²×°Ä£Ê½ (ÎÞ½çÃæ»ò±»¶¯°²×°):
  /S, /SILENT, /QUIET, /PASSIVE, /AUTO
  -S, -SILENT, -QUIET, -PASSIVE, -AUTO
  (Ò²Ö§³ÖÎÞÇ°×º¸ñÊ½£¬Èç SILENT)

Ö¸¶¨°²×°Â·¾¶:
  1. Ê¹ÓÃ /TO ²ÎÊý - ¸ü¸Ä°²×°µÄ¸ùÎ»ÖÃ£¬µ«±£ÁôÄ¬ÈÏÎÄ¼þ¼ÐÃû³Æ¡£
      Ê¾Àý: /TO:"D:\" 
            °²×°µ½: D:\MyApp\ (¼ÙÉèÄ¬ÈÏ°²×°µ½ C:\Program Files\MyApp)
      Ê¾Àý: /TO "D:\MyCompany"
            °²×°µ½: D:\MyCompany\MyApp\

  2. Ê¹ÓÃ /DIR ²ÎÊý - Ö¸¶¨ÍêÕûµÄ×Ô¶¨Òå°²×°Â·¾¶¡£
      Ê¾Àý: /DIR:"D:\MyApp Custom"
            °²×°µ½: D:\MyApp Custom\
      Ê¾Àý: /dir "C:\Program Files\Another Name"

  ×¢Òâ£ºÂ·¾¶Èô°üº¬¿Õ¸ñ£¬ÇëÊ¹ÓÃË«ÒýºÅ°ü¹ü¡£

ÏÔÊ¾´Ë°ïÖú:
  /?, /HELP, /H, -?, -HELP, -H, ?, HELP, H

Ê¹ÓÃÊ¾Àý:
  setup.exe /S /TO:"D:\"          // ¾²Ä¬°²×°µ½DÅÌ
  setup.exe /DIR:"C:\My App" /S   // ¾²Ä¬°²×°µ½×Ô¶¨ÒåÄ¿Â¼
  setup.exe /TO D:\ /PASSIVE      // ±»¶¯Ä£Ê½°²×°µ½DÅÌ
]]
    
    -- ÔÚÏûÏ¢¿òÖÐÏÔÊ¾°ïÖú£¨Èç¹ûÊÇ½»»¥Ä£Ê½£©
    Dialog.Message("°²×°³ÌÐòÃüÁîÐÐ°ïÖú", helpText, MB_OK, MB_ICONINFORMATION)
    -- ÍË³ö°²×°³ÌÐò
    Application.Exit()
end
</Script>
